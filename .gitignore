# Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which can generally be ignored
*.pdb

# Workspace members
*.swp
*.swo

# Project specific
error.log
.DS_Store

# Agent Analysis Reports
*_report.md
*REPORT*.md

# Working analysis/audit notes (not shipped)
docs/

# pi agent artifacts (subagent run outputs/sessions — local only, not shipped)
.pi-subagents/
